              "raw": "{\n  \"email\": \"{{email}}\",\n  \"fullName\": \"Maya Chen\",\n  \"password\": \"{{password}}\",\n  \"preferences\": {\n    \"styles\": [\"minimalist\", \"japandi\"],\n    \"budgetMin\": 500,\n    \"budgetMax\": 2500,\n    \"currency\": \"USD\"\n  }\n}",
              "options": {
