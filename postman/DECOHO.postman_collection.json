      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function readJson() {",
          "  try { return pm.response.json(); } catch (error) { return null; }",
          "}",
          "",
          "function setVar(key, value) {",
          "  if (value === undefined || value === null || value === \"\") return;",
          "  pm.collectionVariables.set(key, String(value));",
          "}",
          "",
          "function getId(value) {",
          "  if (!value) return null;",
          "  if (typeof value === \"string\") return value;",
          "  return value._id || value.id || value.decorPlanId || value.productId || null;",
          "}",
          "",
          "const json = readJson();",
          "if (!json) return;",
          "",
          "const first = Array.isArray(json) ? json[0] : json;",
          "const requestName = pm.info.requestName.toLowerCase();",
          "",
          "setVar(\"accessToken\", json.accessToken);",
          "setVar(\"refreshToken\", json.refreshToken);",
          "if (json.emailVerification) {",
          "  setVar(\"verificationToken\", json.emailVerification.verificationToken);",
          "  setVar(\"verificationLink\", json.emailVerification.verificationLink);",
          "}",
          "",
          "if (json.user) {",
          "  setVar(\"userId\", getId(json.user));",
          "}",
          "",
          "if (requestName.includes(\"room\")) {",
          "  setVar(\"roomId\", getId(first));",
          "}",
          "",
          "if (requestName.includes(\"product\")) {",
          "  setVar(\"productId\", getId(first));",
          "}",
          "",
          "if (requestName.includes(\"decor plan\")) {",
          "  setVar(\"decorPlanId\", json.decorPlanId || getId(first));",
          "  if (Array.isArray(json.recommendedProducts) && json.recommendedProducts[0]) {",
          "    setVar(\"productId\", getId(json.recommendedProducts[0]));",
          "  }",
          "}",
          "",
          "if (requestName.includes(\"favorite\")) {",
          "  setVar(\"favoriteId\", getId(first));",
          "  if (first && first.decorPlanId) {",
          "    setVar(\"decorPlanId\", getId(first.decorPlanId));",
          "  }",
          "}"
        ]
      }
    }
  ],
