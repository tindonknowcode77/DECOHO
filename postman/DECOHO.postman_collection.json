      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"fullName\": \"Maya Chen\",\n  \"password\": \"{{password}}\",\n  \"preferences\": {\n    \"styles\": [\"minimalist\", \"japandi\"],\n    \"budgetMin\": 500,\n    \"budgetMax\": 2500,\n    \"currency\": \"USD\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/register",
              "host": [
                "localhost"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ],
              "protocol": "http",
              "port": "3000"
            },
            "description": "Registers the email in the collection variable, sends/generates verification email link, and stores verificationToken/userId automatically. Login is allowed only after Verify Token or clicking the email link."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);",
                  "if (json.emailVerification && json.emailVerification.verificationToken) pm.collectionVariables.set('verificationToken', json.emailVerification.verificationToken);",
                  "if (json.emailVerification && json.emailVerification.verificationLink) pm.collectionVariables.set('verificationLink', json.emailVerification.verificationLink);"
                ]
              }
            }
          ]
        },
